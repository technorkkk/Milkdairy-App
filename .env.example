# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Database - Transaction Pooler (for Vercel runtime, port 6543)
DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-DB-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require

# Database - Direct Connection (for migrations, port 5432)
DIRECT_URL=postgresql://postgres:[YOUR-DB-PASSWORD]@db.[project-ref].supabase.co:5432/postgres?sslmode=require
